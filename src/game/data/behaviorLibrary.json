  "locations": {
    "square": {
      "nameCn": "广场",
      "description": "小镇中心，有一口古老的水井。集会、交易和信息交换的场所。",
      "winterNote": "水井在隆冬可能结冰，需要破冰取水。"
    },
    "chapel": {
      "nameCn": "废弃教堂",
      "description": "石砌教堂，小镇上最坚固的建筑。修缮后可作为公共起居和避难场所。",
      "winterNote": "石墙保温性最好，隆冬时是全镇的核心避难所。"
    },
    "forge": {
      "nameCn": "旧铁匠铺",
      "description": "废弃的铁匠工坊，炉子尚可修复使用。锻造和烹饪的场所。",
      "winterNote": "锻造炉提供持续热源，也是修理工具的唯一场所。"
    },
    "ruins": {
      "nameCn": "废屋区",
      "description": "一片荒废的民居，墙壁坍塌、屋顶破损。修缮后可变为宜居住所。",
      "winterNote": "修缮进度决定可用住所数量，未修缮的房屋无法抵御寒风。"
    },
    "forest": {
      "nameCn": "森林",
      "description": "小镇外的森林，狩猎、采集和伐木的主要区域。",
      "winterNote": "深冬时极度危险——暴风雪、狼群、迷路风险。"
    },
    "storehouse": {
      "nameCn": "储藏室",
      "description": "半完好的地窖，用于储存物资和食物。",
      "winterNote": "存量逐周递减，合理配给至关重要。"
    }
  },

