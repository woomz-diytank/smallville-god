      "nameCn": "阿尔德里克",
      "age": 45,
      "needs": {
        "SURVIVE": { "weight": 0.5, "style": "务实而自足，靠手艺养活自己" },
        "PRODUCE": { "weight": 0.9, "style": "沉迷于锻造和建造，工作就是他的语言" },
