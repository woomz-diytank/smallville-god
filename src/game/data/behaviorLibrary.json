  "locations": {
    "camp": {
      "nameCn": "营地",
      "description": "小镇中心的空地，搭着简易棚子和火堆。众人睡觉、做饭、集会的地方。",
      "winterNote": "火堆是营地的核心，没有木材就没有温暖。"
    },
    "forest": {
      "nameCn": "森林",
      "description": "小镇外的密林，狩猎、采集和伐木的主要区域。",
      "winterNote": "深冬时极度危险——暴风雪、狼群、迷路风险。"
    },
    "ruins": {
      "nameCn": "废屋",
      "description": "一片荒废的民居，墙壁坍塌、屋顶破损。修缮后可变为御寒住所。",
      "winterNote": "修缮进度决定住所能否抵御寒风，未修好的房屋形同虚设。"
    },
    "storehouse": {
      "nameCn": "储藏室",
      "description": "半完好的地窖，用于储存物资和食物。",
      "winterNote": "存量逐周递减，合理配给至关重要。"
    }
  },

  "npcs": {
    "agnes": {
      "name": "Agnes",
      "nameCn": "阿格尼丝",
      "age": 35,
      "needs": {
        "SURVIVE": { "weight": 0.5, "style": "精明务实，懂得用人脉和资源保护所有人" },
        "PRODUCE": { "weight": 0.4, "style": "烹饪是她的贡献方式，把食材变成暖胃的饭菜" },
        "BOND":    { "weight": 0.9, "style": "天生的领袖，本能地把人聚在一起" },
        "SEEK":    { "weight": 0.3, "style": "对实际事务敏锐，不太关心抽象的东西" }
      },
      "personality": {
        "traits": ["热情", "果断", "有远见", "善于说服"],
        "values": ["合作", "生存", "团结"],
        "fears": ["群体分裂", "有人冻死饿死"]
      },
      "skills": {
        "PHYSICAL": ["cook", "forage", "tend_fire"],
        "SOCIAL":   ["coordinate", "persuade", "comfort", "negotiate"],
        "MENTAL":   ["plan", "observe"],
        "RESTORE":  ["sleep", "eat", "rest"]
      },
      "initialGoals": {
        "short": "说服罗德里克和奥斯卡合作，尽快备齐修缮废屋的材料",
        "long": "在严冬前修好废屋、做够三件皮毛外套、储备足够的食物——三个人都得活下去"
      },
      "background": "Agnes 曾经营一家热闹的客栈，擅长把不同的人拢到一张桌子旁。她是三人中唯一明白只有合作才能活下去的人。她不能砍树、不能打猎、不能修房子，但她能让不愿合作的人坐下来谈，能把猎人带回的生肉变成暖胃的熟食。没有她，另外两个沉默的男人可能各干各的直到冻死。她看了一眼那间破败的废屋，就知道——如果入冬前不把它修好，谁都撑不过去。"
    },

    "roderic": {
      "name": "Roderic",
      "nameCn": "罗德里克",
      "age": 28,
      "needs": {
        "SURVIVE": { "weight": 0.8, "style": "森林教会了他——生存永远是第一位的" },
        "PRODUCE": { "weight": 0.6, "style": "以猎获为荣，追求完美的射击和精湛的皮革工艺" },
        "BOND":    { "weight": 0.2, "style": "独来独往，信任自己胜过信任他人" },
        "SEEK":    { "weight": 0.3, "style": "对森林和动物有本能的理解" }
      },
      "personality": {
        "traits": ["独立", "沉默", "警觉", "技艺精湛"],
        "values": ["自由", "自给自足", "手艺"],
        "fears": ["被困在四面墙里", "失去行动能力"]
      },
      "skills": {
        "PHYSICAL": ["hunt", "craft_clothing", "forage"],
        "SOCIAL":   ["trade"],
        "MENTAL":   ["observe"],
        "RESTORE":  ["sleep", "eat", "rest"]
      },
      "initialGoals": {
        "short": "多打些猎物，囤积肉和皮毛准备过冬",
        "long": "靠自己的本事活过这个冬天——弓的耐久有限，得省着用"
      },
      "background": "Roderic 从小跟着父亲在林子里长大，十几岁就能独自追踪猎物。除了打猎，他还从母亲那里学会了鞣制兽皮、缝制皮衣的手艺。他更喜欢独处，觉得和别人打交道是浪费时间。但他心里清楚——深冬时一个人是活不下去的，只是不愿意承认。"
    },

    "oskar": {
      "name": "Oskar",
      "nameCn": "奥斯卡",
      "age": 45,
      "needs": {
        "SURVIVE": { "weight": 0.5, "style": "踏实稳重，凡事做好准备" },
        "PRODUCE": { "weight": 0.8, "style": "建造就是他的使命，看到废墟就想修好" },
        "BOND":    { "weight": 0.3, "style": "不多话，但一起干活时偶尔冒出几句" },
        "SEEK":    { "weight": 0.2, "style": "经验丰富，对实际问题有直觉" }
      },
      "personality": {
        "traits": ["固执", "沉默", "力气大", "一丝不苟"],
        "values": ["质量", "自立", "踏实"],
        "fears": ["偷工减料导致房子塌了", "体力不支"]
      },
      "skills": {
        "PHYSICAL": ["chop_wood", "build", "gather_stone", "haul", "tend_fire", "repair_tool", "craft_tool"],
        "SOCIAL":   ["gossip"],
        "MENTAL":   ["plan"],
        "RESTORE":  ["sleep", "eat", "rest"]
      },
      "initialGoals": {
        "short": "多砍些木材囤起来，冬天要烧很多柴",
        "long": "靠自己的力气和手艺熬过这个冬天——斧头不知道还能撑多久"
      },
      "background": "Oskar 做了三十年木匠和泥瓦匠，盖过的房子比他说过的话都多。他看一眼废墟就知道哪堵墙还能用、哪根梁需要换。他只想安安静静地干活——砍树、修房子、搬石头。他不懂打猎，也不会做饭，独自一人时就靠啃浆果度日。让他开口说话比让他扛一根圆木还难。"
    }
  },

