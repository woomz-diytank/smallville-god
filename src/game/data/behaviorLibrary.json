    "SOCIAL": [
      { "id": "trade",      "nameCn": "交易",   "description": "与到访的货郎以物易物",               "locations": ["camp"] },
      { "id": "coordinate", "nameCn": "协调分工", "description": "组织众人分配任务、协调行动",         "locations": ["camp"] },
      { "id": "persuade",   "nameCn": "说服",   "description": "说服他人接受某个观点或改变行为",       "locations": ["camp", "ruins", "forest", "storehouse"] },
      { "id": "comfort",    "nameCn": "安慰",   "description": "给予情感支持，安慰沮丧或恐惧的人",     "locations": ["camp", "ruins", "forest", "storehouse"] },
      { "id": "negotiate",  "nameCn": "协商",   "description": "调解分歧，在不同立场之间寻求共识",     "locations": ["camp"] },
