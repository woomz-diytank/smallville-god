{
  "meta": {
    "version": "0.2.0",
    "description": "中世纪荒废小镇冬季生存模拟 - 行为库与物品系统",
    "setting": "8名移民在荒废小镇的基础上合作生活，抵御冬天寒潮",
    "framework": {
      "needLayer": "SURVIVE / PRODUCE / BOND / SEEK — 驱动 NPC 做出行为选择的四种基本需求",
      "behaviorLayer": "PHYSICAL / SOCIAL / MENTAL / RESTORE — 行为与世界交互的四种客观方式",
      "abilityLayer": "每个 NPC 拥有行为库的有限子集，基本技能广泛分布，专精技能少数人掌握",
      "environmentLayer": "地点决定哪些技能可用，工具决定能否执行",
      "itemSourceRule": "每件物品的来源对应行为库中的具体行为：采集(从自然获取) / 制作(从原料加工) / 交易(从外界换取)"
    }
  },

  "needTypes": {
    "SURVIVE": {
      "name": "存续",
      "description": "维持自身作为生物体的持续存在。吃饭、睡觉、避险、治疗、寻找庇护。",
      "axis": "自身 × 物质"
    },
    "PRODUCE": {
      "name": "创造",
      "description": "对物质世界施加作用，产出有形成果。建造、制作、采集、烹饪。",
      "axis": "外部 × 物质"
    },
    "BOND": {
      "name": "联结",
      "description": "与他人建立、维持或改变关系。交谈、合作、竞争、领导、对抗。",
      "axis": "外部 × 精神"
    },
    "SEEK": {
      "name": "求知",
      "description": "理解世界和自身，构建内在的意义体系。观察、探索、学习、反思、祈祷。",
      "axis": "自身 × 精神"
    }
  },

  "behaviorTypes": {
    "PHYSICAL": {
      "name": "劳作",
      "description": "身体作用于物质世界的行为"
    },
    "SOCIAL": {
      "name": "交际",
      "description": "与他人的双向交互"
    },
    "MENTAL": {
      "name": "思索",
      "description": "内在的信息处理与精神活动"
    },
    "RESTORE": {
      "name": "休养",
      "description": "自我恢复与生理维持"
    }
  },

